# Copy this file to .env and fill in your key.
#
# OPTIONAL. MetaCheck works fully without it — you'll just get the built-in
# (already readable) error messages instead of GPT-rewritten ones.
#
# When set, both the CLI (main.py) and the web app (app.py) can rewrite error
# messages in plain, friendly language via GPT-4o-mini. In the web app a
# "plain language" toggle appears on the upload form.
OPENAI_API_KEY=your_key_here
