# Copy this file to .env and fill in what you want to enable.
# MetaCheck works fully with NONE of these set.

# --- Plain-language errors (optional) ---
# When set, the CLI and web app can rewrite error messages in friendly language
# via GPT-4o-mini. In the web app a "plain language" toggle appears.
OPENAI_API_KEY=your_key_here

# --- Spotify track lookup (optional) ---
# Enables the "Search Spotify" tab: pull a real track's metadata by name.
# Create a free app at https://developer.spotify.com/dashboard and copy its
# Client ID / Secret here. Uses the Client Credentials flow (no user login).
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# --- Soundcharts real per-platform streams (optional, PAID) ---
# When set, MetaCheck replaces its modeled market-share split with REAL
# per-platform stream counts by ISRC (Spotify streams, Audiomack plays, and
# other DSPs incl. African). Without these it falls back to the model.
# Get credentials at https://soundcharts.com (developers.soundcharts.com).
SOUNDCHARTS_APP_ID=your_soundcharts_app_id
SOUNDCHARTS_API_KEY=your_soundcharts_api_key
# Optional: override the API base (defaults to the production customer URL).
# SOUNDCHARTS_API_BASE=https://customer.api.soundcharts.com
